# Скопируй в .env.prod и заполни значения
# cp .env.prod.example .env.prod

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=СИЛЬНЫЙ_ПАРОЛЬ_СЮДА
POSTGRES_DB=visual_library

# ─── API ──────────────────────────────────────────────────────────────────────
# Список разрешённых origins через запятую (без слэша в конце)
ALLOWED_ORIGINS=http://ВАШ_ДОМЕН_ИЛИ_IP

# ─── Web ──────────────────────────────────────────────────────────────────────
# URL API, доступный из БРАУЗЕРА пользователя (не из контейнера)
# Если Nginx на порту 80 — без порта, иначе с портом
NEXT_PUBLIC_API_URL=http://ВАШ_ДОМЕН_ИЛИ_IP/api/v1
