# База данных PostgreSQL
# Для локальной разработки: docker compose up -d запустит PostgreSQL с этими параметрами
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/visual_library"

# HTTP-сервер
PORT=3001
NODE_ENV=development

# CORS: список разрешённых origins через запятую
# В продакшне — заменить на реальный домен фронтенда
ALLOWED_ORIGINS="http://localhost:3000"

# JWT: секрет для подписи токенов
# В продакшне — заменить на длинную случайную строку (минимум 32 символа)
JWT_SECRET="dev-secret-change-in-production"
